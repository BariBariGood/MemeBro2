# Local secrets for Supabase Edge Functions development.
# 1. Copy this file to `.env` in this directory (supabase/functions/).
# 2. Replace placeholder values. Never commit `.env`.
#
# Production: use `supabase secrets set <NAME>=<VALUE>` or the Supabase dashboard.

# Required: OpenAI API key for caption and image generation
OPENAI_API_KEY=sk-your_development_key_here

# Required: Shared secret to protect endpoints from abuse
# Clients must send this value in the X-MemeBro-Token header
MEMEBRO_APP_TOKEN=your_shared_secret_here

# Optional: Override default models
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1
