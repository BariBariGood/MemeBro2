{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:assets": "node scripts/build-mediapipe-assets.js",
    "deploy": "wrangler deploy",
    "postinstall": "node scripts/build-mediapipe-assets.js",
    "predev": "npm run build:assets",
    "prestart": "npm run build:assets",
    "pretest": "npm run build:assets",
    "dev": "wrangler dev --port 8787",
    "start": "wrangler dev --port 8787",
    "test": "npm run test:worker && npm run test:ui",
    "test:worker": "vitest --config vitest.config.js",
    "test:ui": "vitest --config vitest.ui.config.js"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "jsdom": "^29.1.1",
    "vitest": "~3.2.0",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "jpeg-js": "^0.4.4"
  }
}
