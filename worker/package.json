{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:assets": "node scripts/build-mediapipe-assets.js",
    "build:hero": "vite build --config hero/vite.config.js",
    "deploy": "wrangler deploy",
    "postinstall": "node scripts/build-mediapipe-assets.js",
    "predev": "npm run build:assets && npm run build:hero",
    "prestart": "npm run build:assets && npm run build:hero",
    "pretest": "npm run build:assets && npm run build:hero",
    "predeploy": "npm run build:hero",
    "dev": "wrangler dev --port 8787",
    "start": "wrangler dev --port 8787",
    "test": "npm run test:worker && npm run test:ui",
    "test:worker": "vitest --config vitest.config.js",
    "test:ui": "vitest --config vitest.ui.config.js"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.3",
    "vitest": "~3.2.0",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
