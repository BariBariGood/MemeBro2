{
  "schemaVersion": "1.3.0",
  "collection": {
    "id": "meme-template-catalog",
    "name": "Meme Template Catalog",
    "description": "Imgflip-sourced meme template dataset for the scrollable grid experience.",
    "totalTemplates": 25,
    "sourcePolicy": {
      "imageAssets": "imgflip-get_memes",
      "notes": "Preview images are locally compressed JPEGs. Full template images are local copies of Imgflip get_memes source assets."
    }
  },
  "grid": {
    "type": "scrollable",
    "scrollDirection": "vertical",
    "responsive": true,
    "itemCard": {
      "clickable": true,
      "labelPosition": "below-image",
      "labelField": "name",
      "tapTarget": "full-card",
      "destinationView": "editor"
    },
    "imageLoading": {
      "strategy": "lazy-progressive",
      "thumbnailSourceField": "images.thumbnail",
      "previewSourceField": "images.preview",
      "fullResolutionSourceField": "images.main",
      "maxInitialLoadMs": 1500,
      "placeholderStyle": "compressed-preview-first",
      "swapToFullThumbnailWhenReady": true
    },
    "interaction": {
      "onTemplateClick": {
        "action": "navigate",
        "targetPage": "editor",
        "routePattern": "/editor/:templateId",
        "prefetchFullResolutionImage": true
      }
    },
    "search": {
      "enabled": true,
      "position": "top-of-grid",
      "placeholder": "Search meme templates by name or tag",
      "matchFields": [
        "name",
        "tags"
      ],
      "filterMode": "hide-non-matches-realtime",
      "maxFilterResponseMs": 500
    },
    "tabs": {
      "enabled": true,
      "defaultTab": "trending",
      "items": [
        {
          "id": "recents",
          "label": "Recents",
          "maxItems": 3,
          "storageKey": "meme-template-recents"
        },
        {
          "id": "trending",
          "label": "Trending",
          "sortBy": "popularityScore",
          "sortDirection": "desc",
          "persistentAcrossSessions": true
        }
      ]
    },
    "breakpoints": {
      "mobile": {
        "maxWidth": 767,
        "columns": 2,
        "thumbnailAspectRatio": "1:1",
        "gap": 12
      },
      "tablet": {
        "minWidth": 768,
        "maxWidth": 1023,
        "columns": 3,
        "thumbnailAspectRatio": "1:1",
        "gap": 16
      },
      "desktop": {
        "minWidth": 1024,
        "columns": 5,
        "thumbnailAspectRatio": "1:1",
        "gap": 20
      }
    }
  },
  "templateSchema": {
    "requiredFields": [
      "id",
      "name",
      "popularityScore",
      "tags",
      "images",
      "faceRegions",
      "display",
      "editorTarget"
    ],
    "fieldNotes": {
      "id": "Stable unique identifier for each meme template.",
      "name": "Display name shown to users.",
      "popularityScore": "Relative usage score from 1-100.",
      "tags": "Search and filter tags tied to the meme format.",
      "images": "Local paths for the compressed preview, thumbnail, and full meme template image.",
      "faceRegions": "Array of face bounding boxes relative to source image pixels.",
      "display": "Card-level metadata for showing the meme name below the image in the grid.",
      "editorTarget": "Navigation contract for opening the future editor page with the full-resolution image."
    }
  },
  "templateDefaults": {
    "display": {
      "showNameBelowImage": true,
      "showPopularityBadge": false
    },
    "editorTarget": {
      "type": "route",
      "layout": "edit",
      "routePattern": "/editor/:templateId",
      "loadFullResolutionOnOpen": true
    }
  },
